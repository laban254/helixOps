# =========================

# DATABASE

# =========================

POSTGRES_USER=helixops
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=helixops

# Used by your backend (HelixOps agent)

DATABASE_URL=postgresql://helixops:${POSTGRES_PASSWORD}@postgres:5432/helixops

# =========================

# GRAFANA

# =========================

GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=change_this_too

# =========================

# HELIXOPS APP

# =========================

HELIX_ENV=production
HELIX_DB_PASSWORD=${POSTGRES_PASSWORD}

# =========================

# OPTIONAL (OBSERVABILITY)

# =========================

PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200

# =========================

# OLLAMA (if needed)

# =========================

OLLAMA_MODELS=/root/.ollama/models
